{
  "name": "steno",
  "version": "0.0.0",
  "private": true,
  "description": "Steno — 跨平台桌面速记应用（Tauri 2 + Rust + Vue 3）",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "icons": "tauri icon src-tauri/icons/icon.svg --output src-tauri/icons",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "lint": "oxlint --fix && eslint --fix .",
    "fmt": "oxfmt",
    "commit": "sa git-commit",
    "commit:zh": "sa git-commit -l=zh-cn",
    "cleanup": "sa cleanup",
    "release": "sa release",
    "update-pkg": "sa update-pkg",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@iconify/vue": "5.0.0",
    "@lezer/highlight": "^1.2.3",
    "@sa/axios": "workspace:*",
    "@sa/color": "workspace:*",
    "@sa/hooks": "workspace:*",
    "@sa/utils": "workspace:*",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@vueuse/core": "14.2.1",
    "dayjs": "1.11.19",
    "defu": "6.1.4",
    "echarts": "^6.1.0",
    "markdown-it": "^14.1.1",
    "marked": "^16.0.0",
    "naive-ui": "2.44.1",
    "pinia": "3.0.4",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.6",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "vue": "3.5.29",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@sa/scripts": "workspace:*",
    "@sa/uno-preset": "workspace:*",
    "@soybeanjs/eslint-config-vue": "^0.0.2",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "25.3.5",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "@vue/test-utils": "^2.4.6",
    "consola": "3.4.2",
    "eslint": "10.0.3",
    "jsdom": "^27.0.0",
    "kolorist": "1.8.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unocss": "^66.6.6",
    "vite": "7.3.1",
    "vite-plugin-progress": "0.0.7",
    "vite-plugin-vue-devtools": "8.0.7",
    "vitest": "^4.0.0",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.5"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm sa git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
