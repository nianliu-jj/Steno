{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steno",
  "version": "0.0.0",
  "identifier": "com.steno.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Steno",
        "width": 800,
        "height": 600,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": false
      },
      {
        "label": "quicknote",
        "url": "quicknote.html",
        "title": "Steno · 速记",
        "width": 400,
        "height": 300,
        "minWidth": 320,
        "minHeight": 220,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
